# Neon PostgreSQL connection string (find this in Neon dashboard)
DATABASE_URL=postgres://user:password@ep-cold-shadow-123456.eu-central-1.aws.neon.tech/stor?sslmode=require

# Random string for signing JWTs (generate using e.g., `openssl rand -base64 32`)
JWT_SECRET=your_super_secret_jwt_key_here

# (Optional) Email config for forgot password flow
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@stor.app
